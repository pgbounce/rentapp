{
  "name": "@toprent/config",
  "private": true,
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./src/api.ts",
      "default": "./dist/api.js"
    },
    "./worker": {
      "types": "./src/worker.ts",
      "default": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean.mjs dist && node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "zod": "^4.1.11"
  }
}
