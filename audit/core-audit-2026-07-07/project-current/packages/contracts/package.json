{
  "name": "@toprent/contracts",
  "private": true,
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./health": {
      "types": "./src/health.ts",
      "default": "./dist/health.js"
    },
    "./api": {
      "types": "./src/api.ts",
      "default": "./dist/api.js"
    },
    "./tenancy": {
      "types": "./src/tenancy.ts",
      "default": "./dist/tenancy.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean.mjs dist && node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js --noEmit"
  }
}
