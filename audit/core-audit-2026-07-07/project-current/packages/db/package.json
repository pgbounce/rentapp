{
  "name": "@toprent/db",
  "private": true,
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean.mjs dist && node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "generate": "drizzle-kit generate",
    "provision": "node ./scripts/provision.mjs",
    "migrate": "node ./scripts/migrate.mjs",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "@toprent/contracts": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.4"
  }
}
