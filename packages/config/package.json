{
  "name": "@toprent/config",
  "private": true,
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./src/api.ts",
      "default": "./dist/api.js"
    },
    "./web": {
      "types": "./src/web.ts",
      "default": "./dist/web.js"
    },
    "./worker": {
      "types": "./src/worker.ts",
      "default": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.1.11"
  }
}
